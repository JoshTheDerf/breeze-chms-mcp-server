# Breeze ChMS Configuration
# Copy this file to .env and fill in your values

# Your Breeze subdomain (e.g., "mychurch" for mychurch.breezechms.com)
BREEZE_SUBDOMAIN=your-church-subdomain

# Your Breeze API key (get from Extensions > API page in Breeze)
BREEZE_API_KEY=your-api-key-here

# Optional: Enable debug logging
# DEBUG=breeze-chms-mcp-server
